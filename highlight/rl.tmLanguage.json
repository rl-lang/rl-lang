{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "rl-lang",
  "scopeName": "source.rl",
  "fileTypes": ["rl"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#characters" },
    { "include": "#numbers" },
    { "include": "#keywords_control" },
    { "include": "#keywords_declaration" },
    { "include": "#keywords_type" },
    { "include": "#keywords_import" },
    { "include": "#keywords_logical" },
    { "include": "#constants" },
    { "include": "#function_def" },
    { "include": "#function_call" },
    { "include": "#method_call" },
    { "include": "#operators" },
    { "include": "#punctuation" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.rl",
          "match": "//.*$"
        },
        {
          "name": "comment.block.rl",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },

    "strings": {
      "name": "string.quoted.double.rl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.rl",
          "match": "\\\\(n|t|r|\\\\|\"|0)"
        }
      ]
    },

    "characters": {
      "name": "string.quoted.single.rl",
      "match": "'([^'\\\\]|\\\\.)'"
    },

    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.rl",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.rl",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },

    "keywords_control": {
      "name": "keyword.control.rl",
      "match": "\\b(if|else|while|for|in|return|break|continue)\\b"
    },

    "keywords_declaration": {
      "name": "keyword.declaration.rl",
      "match": "\\b(dec|const|fn|arr)\\b"
    },

    "keywords_type": {
      "name": "storage.type.rl",
      "match": "\\b(int|float|bool|string|char|array)\\b"
    },

    "keywords_import": {
      "name": "keyword.other.import.rl",
      "match": "\\b(get|from)\\b"
    },

    "keywords_logical": {
      "name": "keyword.operator.logical.rl",
      "match": "\\b(and|or)\\b"
    },

    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.rl",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.rl",
          "match": "\\bnull\\b"
        }
      ]
    },

    "function_def": {
      "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "keyword.declaration.function.rl" },
        "2": { "name": "entity.name.function.rl" }
      }
    },

    "function_call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.rl" }
      }
    },

    "method_call": {
      "match": "\\.([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.method.rl" }
      }
    },

    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.rl",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.rl",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.arithmetic.rl",
          "match": "(\\+|-|\\*|/)"
        },
        {
          "name": "keyword.operator.bang.rl",
          "match": "(!#|!)"
        },
        {
          "name": "keyword.operator.arrow.rl",
          "match": "->"
        },
        {
          "name": "keyword.operator.range.rl",
          "match": "\\.\\."
        },
        {
          "name": "keyword.operator.path.rl",
          "match": "::"
        }
      ]
    },

    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.comma.rl",
          "match": ","
        },
        {
          "name": "punctuation.terminator.semicolon.rl",
          "match": ";"
        },
        {
          "name": "punctuation.accessor.dot.rl",
          "match": "\\."
        },
        {
          "name": "punctuation.definition.block.rl",
          "match": "[{}]"
        },
        {
          "name": "punctuation.definition.params.rl",
          "match": "[()]"
        },
        {
          "name": "punctuation.definition.array.rl",
          "match": "[\\[\\]]"
        }
      ]
    },

    "identifiers": {
      "name": "variable.other.rl",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
